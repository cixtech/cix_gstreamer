+/**
+ * _get_egl_dmabuf_supported_formats:
+ *
+ * Enumerate DMA-BUF formats supported by the default EGL display via
+ * eglQueryDmaBufFormatsEXT and map them to GstVideoFormat names.
+ * For DRM_FORMAT_YUV420_8BIT, DRM_FORMAT_YUV420_10BIT and DRM_FORMAT_YUV422,
+ * eglQueryDmaBufModifiersEXT must list the ARM AFBC 16x16 modifier before the
+ * corresponding GstVideoFormat name is added.
+ * Caller must g_value_unset() the returned value.
+ *
+ * Returns: (transfer full): a GValue of type GST_TYPE_LIST containing
+ *   format strings, or %NULL if enumeration fails or EGL display is unavailable.
+ *
+ * Opens the default EGL display with eglInitialize() for the probe and always
+ * calls eglTerminate() on the same display before returning if initialization
+ * succeeded (EGL reference counting balances the pair).
+ */
+static GValue *
+_get_egl_dmabuf_supported_formats (void)
+{
+  EGLDisplay egl_dpy = EGL_NO_DISPLAY;
+  EGLint major, minor;
+  const gchar *egl_exts = NULL;
+  EGLBoolean (*query_formats) (EGLDisplay, EGLint, EGLint *, EGLint *) = NULL;
+  EGLint *formats = NULL;
+  EGLint num_formats = 0;
+  GValue *result = NULL;
+  gboolean egl_inited = FALSE;
+  gint i;
+
+  egl_dpy = eglGetDisplay (EGL_DEFAULT_DISPLAY);
+  if (egl_dpy == EGL_NO_DISPLAY) {
+    return NULL;
+  }
+
+  if (!eglInitialize (egl_dpy, &major, &minor)) {
+    return NULL;
+  }
+  egl_inited = TRUE;
+
+  egl_exts = eglQueryString (egl_dpy, EGL_EXTENSIONS);
+  if (!egl_exts
+      || !gst_gl_check_extension ("EGL_EXT_image_dma_buf_import_modifiers",
+          egl_exts)) {
+    goto out;
+  }
+
+  query_formats = (void *) eglGetProcAddress ("eglQueryDmaBufFormatsEXT");
+  if (!query_formats) {
+    goto out;
+  }
+
+  if (!query_formats (egl_dpy, 0, NULL, &num_formats) || num_formats <= 0) {
+    goto out;
+  }
+
+  formats = g_new (EGLint, num_formats);
+  if (!query_formats (egl_dpy, num_formats, formats, &num_formats)) {
+    g_free (formats);
+    formats = NULL;
+    goto out;
+  }
+
+  result = g_new0 (GValue, 1);
+  g_value_init (result, GST_TYPE_LIST);
+
+  for (i = 0; i < num_formats; i++) {
+    GstVideoFormat v_format;
+    gboolean is_yuv_afbc_fourcc =
+        (formats[i] == DRM_FORMAT_YUV420_8BIT
+        || formats[i] == DRM_FORMAT_YUV420_10BIT
+        || formats[i] == DRM_FORMAT_YUV422);
+
+    if (is_yuv_afbc_fourcc
+        && !_egl_dmabuf_query_afbc_modifier_supported (egl_dpy, formats[i]))
+      continue;
+
+    v_format = gst_video_dma_drm_fourcc_to_format (formats[i]);
+    if (v_format != GST_VIDEO_FORMAT_UNKNOWN) {
+      const gchar *name = gst_video_format_to_string (v_format);
+      GValue val = G_VALUE_INIT;
+      g_value_init (&val, G_TYPE_STRING);
+      g_value_set_string (&val, name);
+      gst_value_list_append_value (result, &val);
+      g_value_unset (&val);
+    }
+  }
+
+  g_free (formats);
+  formats = NULL;
+
+  if (gst_value_list_get_size (result) == 0) {
+    g_value_unset (result);
+    g_free (result);
+    result = NULL;
+  }
+
+out:
+  if (egl_inited) {
+    eglTerminate (egl_dpy);
+  }
+  return result;
+}
