+static gboolean
+gst_v4l2_video_update_resolution (GstVideoDecoder * decoder,
+    GstCaps * caps, guint max_width, gboolean set_compose)
+{
+  GstV4l2VideoDec *self = GST_V4L2_VIDEO_DEC (decoder);
+  GstStructure *s = gst_caps_get_structure (caps, 0);
+  GstV4l2Error error;
+  gboolean updated = FALSE;
+  const GValue *val;
+
+  if ((val = gst_structure_get_value (s, "width"))) {
+    gint w = 0, h = 0;
+    if (G_VALUE_TYPE (val) == G_TYPE_INT)
+      w = g_value_get_int (val);
+    if ((val = gst_structure_get_value (s, "height")))
+      if (G_VALUE_TYPE (val) == G_TYPE_INT)
+        h = g_value_get_int (val);
+    if (max_width < w) {
+      /* If resolution exceeds downstream caps, try to set compose region of selection to downscale */
+      struct v4l2_rect rect = { 0 };
+      rect.width = max_width;
+      rect.height = h * max_width / w;
+      if (set_compose) {
+        /* Set format first */
+        GstCaps *tmp = gst_caps_copy_nth (caps, 0);
+        tmp = gst_caps_fixate (tmp);
+        gst_v4l2_object_update_format (self->v4l2capture, tmp, &error);
+        gst_caps_unref (tmp);
+        /* Then set compose to get downscaled resolution of specified format */
+        if (!gst_v4l2_object_set_compose (self->v4l2capture, &rect))
+          return FALSE;
+      }
+      if (rect.width <= max_width) {
+        /* Now update width and height in caps with driver returned compose region */
+        GValue v = G_VALUE_INIT;
+        g_value_init (&v, G_TYPE_INT);
+        g_value_set_int (&v, rect.width + rect.left);
+        gst_structure_set_value (s, "width", &v);
+        g_value_set_int (&v, rect.height + rect.top);
+        gst_structure_set_value (s, "height", &v);
+        updated = TRUE;
+      }
+    }
+  }
+
+  return updated;
+}
+
+static GstCaps *
+gst_v4l2_video_try_downscaling_caps (GstVideoDecoder * decoder,
+    GstCaps * filter, gboolean downscale)
+{
+  /* if hardware supports scaling, try to adjust width and height in filter, and get caps again */
+  GstV4l2VideoDec *self = GST_V4L2_VIDEO_DEC (decoder);
+  GstCaps *peer_caps = gst_pad_peer_query_caps (decoder->srcpad, NULL);
+  gint peer_caps_size = gst_caps_get_size (peer_caps);
+  gint caps_size = gst_caps_get_size (filter);
+  GstCaps *out_caps = gst_caps_new_empty ();
+  gint i, j;
+
+  if (!out_caps)
+    return NULL;
+
+  for (i = 0; i < peer_caps_size; i++) {
+    const GstStructure *caps_s = gst_caps_get_structure (peer_caps, i);
+    const GValue *val;
+    gint max_w = G_MAXINT;
+    val = gst_structure_get_value (caps_s, "width");
+    if (G_IS_VALUE (val) && G_VALUE_TYPE (val) == GST_TYPE_INT_RANGE)
+      max_w = gst_value_get_int_range_max (val);
+    else if (G_IS_VALUE (val) && G_VALUE_TYPE (val) == G_TYPE_INT)
+      max_w = g_value_get_int (val);
+    else
+      continue;
+
+    for (j = 0; j < caps_size; j++) {
+      GstCaps *tmp = gst_caps_copy_nth (filter, j);
+      if (gst_v4l2_video_update_resolution (decoder, tmp, max_w, downscale)) {
+        out_caps = gst_caps_merge (out_caps, tmp);
+      }
+    }
+  }
+
+  gst_caps_unref (peer_caps);
+  GST_DEBUG_OBJECT (self, "updated filter %" GST_PTR_FORMAT, out_caps);
+  return out_caps;
+}
+
+static void
+gst_v4l2_video_dec_deprioritize_rgb (GstCaps * caps)
+{
+  gint caps_size = gst_caps_get_size (caps);
+  gint rgb_caps_count = 0;
+  gint i;
+
+  if (caps_size < 2)
+    return;
+
+  for (i = 0; i < caps_size; i++) {
+    GstStructure *s = gst_caps_get_structure (caps, i);
+    const gchar *format = gst_structure_get_string (s, "format");
+
+    if (g_str_equal (format, "RGB")) {
+      s = gst_caps_steal_structure (caps, i);
+      gst_caps_append_structure (caps, s);
+      rgb_caps_count++;
+    }
+  }
+}
