+static gboolean
+_egl_dmabuf_query_afbc_modifier_supported (EGLDisplay egl_dpy, EGLint fourcc)
+{
+  EGLBoolean (*query_modifiers) (EGLDisplay, EGLint, EGLint, EGLuint64KHR *,
+      EGLBoolean *, EGLint *) =
+      (void *) eglGetProcAddress ("eglQueryDmaBufModifiersEXT");
+  const guint64 afbc_modifier =
+      DRM_FORMAT_MOD_ARM_AFBC (AFBC_FORMAT_MOD_BLOCK_SIZE_16x16);
+  EGLint num_modifiers = 0;
+  EGLuint64KHR *modifiers = NULL;
+  EGLBoolean *external_only = NULL;
+  EGLBoolean ret;
+  gint m;
+
+  if (!query_modifiers)
+    return FALSE;
+
+  ret = query_modifiers (egl_dpy, fourcc, 0, NULL, NULL, &num_modifiers);
+  if (!ret || num_modifiers <= 0)
+    return FALSE;
+
+  modifiers = g_new (EGLuint64KHR, num_modifiers);
+  external_only = g_new (EGLBoolean, num_modifiers);
+  ret = query_modifiers (egl_dpy, fourcc, num_modifiers, modifiers,
+      external_only, &num_modifiers);
+  g_free (external_only);
+
+  if (!ret || num_modifiers <= 0) {
+    g_free (modifiers);
+    return FALSE;
+  }
+
+  for (m = 0; m < num_modifiers; m++) {
+    if (modifiers[m] == afbc_modifier) {
+      g_free (modifiers);
+      return TRUE;
+    }
+  }
+
+  g_free (modifiers);
+  return FALSE;
+}
