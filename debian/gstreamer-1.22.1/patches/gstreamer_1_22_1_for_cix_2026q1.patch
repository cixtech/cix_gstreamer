+        GstVideoFormat v_format = gst_video_format_from_string (format_str);
+        guint64 modifier = DRM_FORMAT_MOD_LINEAR;
+        guint32 fourcc = gst_video_dma_drm_fourcc_from_format (v_format);
+
+        if (v_format == GST_VIDEO_FORMAT_YUV420_AFBC_8 ||
+            v_format == GST_VIDEO_FORMAT_YUV420_AFBC_10 ||
+            v_format == GST_VIDEO_FORMAT_YUV422_AFBC_8) {
+          modifier = DRM_FORMAT_MOD_ARM_AFBC (AFBC_FORMAT_MOD_BLOCK_SIZE_16x16);
