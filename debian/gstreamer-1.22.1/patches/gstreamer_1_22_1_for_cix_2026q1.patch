+/**
+ * _filter_dmabuf_caps_by_egl_formats:
+ * @caps: caps to filter (will be consumed)
+ * @egl_formats: GValue of type GST_TYPE_LIST of format strings supported by EGL
+ *
+ * Copies @caps; for structures with MEMORY_DMABUF feature sets format to @egl_formats.
+ * then intersects with the original caps. Returns the intersection if
+ * non-empty, otherwise NULL. Caller must unref the original @caps (consumed).
+ */
+static GstCaps *
+_filter_dmabuf_caps_by_egl_formats (GstCaps * caps, const GValue * egl_formats)
+{
+  GstCaps *egl_caps = gst_caps_new_empty ();
+  GstCaps *intersected;
+  guint n = gst_caps_get_size (caps);
+  guint i;
+
+  for (i = 0; i < n; i++) {
+    GstStructure *s = gst_caps_get_structure (caps, i);
+    GstCapsFeatures *features = gst_caps_get_features (caps, i);
+    GstStructure *s_copy = gst_structure_copy (s);
+    /* set format to egl formats for dmabuf caps */
+    if (gst_caps_features_contains (features, GST_CAPS_FEATURE_MEMORY_DMABUF)) {
+      gst_structure_set_value (s_copy, "format", egl_formats);
+    }
+    gst_caps_append_structure_full (egl_caps, s_copy,
+        gst_caps_features_copy (features));
+  }
+
+  egl_caps = gst_caps_simplify (egl_caps);
+  intersected = gst_caps_intersect (egl_caps, caps);
+  gst_caps_unref (caps);
+  gst_caps_unref (egl_caps);
+
+  if (!gst_caps_is_empty (intersected))
+    return gst_caps_simplify (intersected);
+
+  gst_caps_unref (intersected);
+  return NULL;
+}
