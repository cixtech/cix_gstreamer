+{
+  GstV4l2Object *obj = pool->obj;
+
+  if (obj->type == V4L2_BUF_TYPE_VIDEO_CAPTURE ||
+      obj->type == V4L2_BUF_TYPE_VIDEO_CAPTURE_MPLANE) {
+    guint32 pixelformat = obj->fmtdesc->pixelformat;
