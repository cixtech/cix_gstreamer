+static void
+gst_v4l2_buffer_pool_add_crop_meta (GstV4l2BufferPool * pool,
+    GstBuffer * buffer)
+{
+  GstV4l2Object *obj = pool->obj;
+
+  if (obj->type == V4L2_BUF_TYPE_VIDEO_CAPTURE ||
+      obj->type == V4L2_BUF_TYPE_VIDEO_CAPTURE_MPLANE) {
+    guint32 pixelformat = obj->fmtdesc->pixelformat;
+    if (pixelformat == V4L2_PIX_FMT_YUV420_AFBC_8 ||
+        pixelformat == V4L2_PIX_FMT_YUV420_AFBC_10 ||
+        pixelformat == V4L2_PIX_FMT_YUV422_AFBC_8 ||
+        pixelformat == V4L2_PIX_FMT_YUV422_AFBC_10) {
+      GstVideoCropMeta *crop_meta;
+      struct v4l2_selection sel;
+      struct v4l2_crop crop;
+      struct v4l2_rect *r = NULL;
+      /* Use the default compose rectangle */
+      memset (&sel, 0, sizeof (struct v4l2_selection));
+      sel.type = obj->type;
+      sel.target = V4L2_SEL_TGT_COMPOSE;
+      if (obj->ioctl (obj->video_fd, VIDIOC_G_SELECTION, &sel) >= 0) {
+        r = &sel.r;
+      } else {
+        /* For ancient kernels, fall back to G_CROP */
+        crop.type = obj->type;
+        if (obj->ioctl (obj->video_fd, VIDIOC_G_CROP, &crop) >= 0) {
+          r = &crop.c;
+        }
+      }
+
+      if (r) {
+        crop_meta = gst_buffer_add_video_crop_meta (buffer);
+        crop_meta->x = r->left;
+        crop_meta->y = r->top;
+        crop_meta->width = r->width;
+        crop_meta->height = r->height;
+        GST_DEBUG_OBJECT (pool, "crop meta (%d, %d) %dx%d", crop_meta->x,
+            crop_meta->y, crop_meta->width, crop_meta->height);
+      }
+    }
+  }
+
+  return;
+}
