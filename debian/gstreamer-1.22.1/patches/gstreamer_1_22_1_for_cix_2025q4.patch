+static void
+gst_v4l2_get_driver_max_buffers (GstV4l2Object * v4l2object)
+{
+  struct v4l2_control control = { 0, };
+
+  g_return_if_fail (GST_V4L2_IS_OPEN (v4l2object));
+
+  if (V4L2_TYPE_IS_OUTPUT (v4l2object->type))
+    return;
+  else
+    control.id = V4L2_CID_MVE_VIDEO_MAX_BUFFERS_FOR_CAPTURE;
+
+  if (v4l2object->ioctl (v4l2object->video_fd, VIDIOC_G_CTRL, &control) == 0) {
+    GST_DEBUG_OBJECT (v4l2object->dbg_obj,
+        "driver requires a maximum of %d buffers", control.value);
+    v4l2object->max_buffers = control.value;
+  } else {
+    v4l2object->max_buffers = 32;
+  }
+}
