+static void
+gst_v4l2_object_add_hdr_colorimetry (GstV4l2Object * v4l2object,
+    struct v4l2_format *fmt, GValue * list)
+{
+  GstVideoColorimetry cinfo, ret_cinfo;
+  enum v4l2_colorspace colorspace = 0;
+  enum v4l2_quantization range = 0;
+  enum v4l2_ycbcr_encoding matrix = 0;
+  enum v4l2_xfer_func transfer = 0;
+  const gchar *hdr_cnames[] = {
+    GST_VIDEO_COLORIMETRY_BT2100_PQ,
+    GST_VIDEO_COLORIMETRY_BT2020_10,
+    GST_VIDEO_COLORIMETRY_BT2100_HLG,
+    NULL
+  };
+  gint i = 0;
+
+  while (hdr_cnames[i] != NULL) {
+    gst_video_colorimetry_from_string (&cinfo, hdr_cnames[i]);
+
+    if (cinfo.primaries == GST_VIDEO_COLOR_PRIMARIES_BT2020) {
+      colorspace = V4L2_COLORSPACE_BT2020;
+    } else {
+      GST_WARNING_OBJECT (v4l2object->dbg_obj,
+          "Colorimetry primaries %d is not expected for %s", cinfo.primaries,
+          hdr_cnames[i]);
+      i++;
+      continue;
+    }
+
+    if (cinfo.matrix == GST_VIDEO_COLOR_MATRIX_BT2020) {
+      matrix = V4L2_YCBCR_ENC_BT2020;
+    } else {
+      GST_WARNING_OBJECT (v4l2object->dbg_obj,
+          "Colorimetry matrix %d is not expected for %s", cinfo.matrix,
+          hdr_cnames[i]);
+      i++;
+      continue;
+    }
+
+    if (cinfo.transfer == GST_VIDEO_TRANSFER_SMPTE2084) {
+      transfer = V4L2_XFER_FUNC_SMPTE2084;
+    } else if (cinfo.transfer == GST_VIDEO_TRANSFER_BT2020_10) {
+      transfer = V4L2_XFER_FUNC_BT2020_10;
+    } else if (cinfo.transfer == GST_VIDEO_TRANSFER_ARIB_STD_B67) {
+      transfer = V4L2_XFER_FUNC_HLG;
+    } else {
+      GST_WARNING_OBJECT (v4l2object->dbg_obj,
+          "Colorimetry transfer %d is not expected for %s", cinfo.transfer,
+          hdr_cnames[i]);
+      i++;
+      continue;
+    }
+
+    range = V4L2_QUANTIZATION_LIM_RANGE;
+
+    if (V4L2_TYPE_IS_MULTIPLANAR (v4l2object->type)) {
+      fmt->fmt.pix_mp.colorspace = colorspace;
+      fmt->fmt.pix_mp.xfer_func = transfer;
+      fmt->fmt.pix_mp.ycbcr_enc = matrix;
+      fmt->fmt.pix_mp.quantization = range;
+    } else {
+      fmt->fmt.pix.colorspace = colorspace;
+      fmt->fmt.pix.xfer_func = transfer;
+      fmt->fmt.pix.ycbcr_enc = matrix;
+      fmt->fmt.pix.quantization = range;
+    }
+
+    if (gst_v4l2_object_try_fmt (v4l2object, fmt) == 0) {
+      if (gst_v4l2_object_get_colorspace (v4l2object, fmt, &ret_cinfo)) {
+        /* Keep the original transfer if they are functionally the same */
+        if (cinfo.transfer == GST_VIDEO_TRANSFER_BT2020_10 &&
+            ret_cinfo.transfer == GST_VIDEO_TRANSFER_BT2020_12)
+          ret_cinfo.transfer = cinfo.transfer;
+        if (gst_video_colorimetry_is_equal (&cinfo, &ret_cinfo)) {
+          gst_v4l2_object_fill_colorimetry_list (list, &cinfo);
+        }
+      }
+    }
+
+    i++;
+  }
+}
